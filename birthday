<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Birthday Network</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body { font-family: Arial; background:#0f172a; color:white; padding:20px; }
    .container { max-width:700px; margin:auto; }
    input, textarea, button { width:100%; margin:5px 0; padding:10px; border-radius:8px; border:none; }
    button { background:#4f46e5; color:white; cursor:pointer; }
    .entry { background:#1e293b; padding:15px; margin-top:10px; border-radius:10px; }
  </style>
</head>

<body>
<div class="container">

  <h1>🎂 Birthday Network</h1>

  <form id="form">
    <input id="name" placeholder="Name" required>
    <input id="birthday" type="date" required>
    <input id="platform" placeholder="Plattform">
    <textarea id="comment" placeholder="Kommentar"></textarea>
    <button type="submit">Speichern</button>
  </form>

  <div id="list"></div>

</div>

<script type="module">
import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm";

const SUPABASE_URL = "https://hguiwubwzdhnbbvzacxq.supabase.co";
const SUPABASE_KEY = "sb_publishable_9Yfi0L2etWp5HpXHUEMsCA_ZX7lriPq";

const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

const form = document.getElementById("form");
const list = document.getElementById("list");

async function load() {
  const { data } = await supabase
    .from("birthdays")
    .select("*")
    .order("birthday", { ascending: true });

  list.innerHTML = "";

  data.forEach(e => {
    list.innerHTML += `
      <div class="entry">
        <b>${e.name}</b><br>
        🎂 ${e.birthday}<br>
        🌐 ${e.platform}<br>
        📝 ${e.comment}
      </div>
    `;
  });
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  await supabase.from("birthdays").insert([{
    name: name.value,
    birthday: birthday.value,
    platform: platform.value,
    comment: comment.value
  }]);

  form.reset();
  load();
});

load();
</script>

</body>
</html>
